---
import { Code, Cpu, Layers3, Sparkles, Target } from "@lucide/astro";

const topFeatures = [
  {
    title: "Rich Card Types",
    description:
      "Create basic, cloze, image occlusion, multiple choice, and ordered questions in one flow without splitting your study process.",
    Icon: Layers3,
  },
  {
    title: "Companion",
    description:
      "Companion turns your notes into flashcards, tests, and study support on demand, helping you go from raw material to review-ready practice faster.",
    Icon: Sparkles,
  },
];

const bottomFeatures = [
  {
    title: "Coach",
    description:
      "Use adaptive guidance for weak areas, get focused follow-up prompts, and keep every session tied to your real notes.",
    Icon: Target,
  },
  {
    title: "FSRS",
    description:
      "Retention-based spacing decides when cards return, balancing workload and long-term memory so reviews stay consistent and sustainable.",
    Icon: Cpu,
  },
];

const carouselSlides = [
  {
    kicker: "Markdown first",
    title: "Multiple Choice for fast checks.",
    description:
      "Use MCQs when you want clear distractors and exam-style practice from the notes you already trust.",
    primaryLabel: "See the multiple-choice format",
    primaryHref: "./Multiple-Choice-Questions",
    secondaryLabel: "See other flashcard types",
    secondaryHref: "./Flashcards",
    codeLabel: "In your note",
    code: [
      "T | Mitochondria function |",
      "MCQ | What is the main function of mitochondria? |",
      "A | Protein synthesis |",
      "B | ATP production |",
      "C | DNA storage |",
      "D | Lipid transport |",
      "ANS | B |",
      "I | Mitochondria generate ATP through cellular respiration |",
      "G | Cell biology |",
    ].join("\n"),
  },
  {
    kicker: "Markdown first",
    title: "Cloze for precise recall.",
    description:
      "Cloze cards hide key terms in context, so you practice exact recall without losing the original meaning of your note.",
    primaryLabel: "See the cloze format",
    primaryHref: "./Cloze-Flashcards",
    secondaryLabel: "See other flashcard types",
    secondaryHref: "./Flashcards",
    codeLabel: "In your note",
    code: [
      "T | Biology core facts |",
      "C | Photosynthesis occurs in the {{chloroplast}} |",
      "C | The powerhouse of the cell is the {{mitochondrion}} |",
      "C | Water boils at {{100 degrees Celsius}} at sea level |",
      "I | Cloze cards are best for exact terms and formulas |",
      "G | Biology |",
    ].join("\n"),
  },
  {
    kicker: "Markdown first",
    title: "Ordered Questions for sequence memory.",
    description:
      "Train process memory with drag-to-order review that mirrors the exact sequence you authored in your markdown.",
    primaryLabel: "See the ordered-question format",
    primaryHref: "./Ordered-Questions",
    secondaryLabel: "See other flashcard types",
    secondaryHref: "./Flashcards",
    codeLabel: "In your note",
    code: [
      "T | Water cycle |",
      "OQ | Arrange the stages of the water cycle in order |",
      "1 | Evaporation |",
      "2 | Condensation |",
      "3 | Precipitation |",
      "4 | Collection |",
      "I | Water moves continuously through the atmosphere and the Earth's surface |",
      "G | Earth science |",
    ].join("\n"),
  },
  {
    kicker: "Markdown first",
    title: "Basic cards for direct Q and A.",
    description:
      "Use simple front-back cards for fast facts, definitions, and high-frequency prompts you want to review every session.",
    primaryLabel: "See the basic format",
    primaryHref: "./Basic-&-Reversed-Flashcards",
    secondaryLabel: "See other flashcard types",
    secondaryHref: "./Flashcards",
    codeLabel: "In your note",
    code: [
      "T | Geography quick fact |",
      "Q | What is the capital of Japan? |",
      "A | Tokyo |",
      "I | Use basic cards for direct one-step recall |",
      "G | Geography |",
    ].join("\n"),
  },
];
---

<div class="home-panels">
  <div class="feature-grid" role="list" aria-label="LearnKit homepage highlights">
    {
      topFeatures.map(({ title, description, Icon }) => (
        <article class="feature-card" role="listitem">
          <p class="feature-title">
            <span class="feature-icon" aria-hidden="true">
              <Icon size={18} stroke-width={2.25} />
            </span>
            <span>{title}</span>
          </p>
          <p class="feature-body">{description}</p>
        </article>
      ))
    }
  </div>

  <section class="workflow-carousel" data-carousel aria-label="Flashcard format carousel">
    <div class="carousel-track">
      {
        carouselSlides.map((slide, index) => (
          <article class="workflow-card workflow-slide" data-slide hidden={index !== 0}>
            <div class="workflow-copy">
              <p class="feature-title workflow-kicker">
                <span class="feature-icon" aria-hidden="true">
                  <Code size={18} stroke-width={2.25} />
                </span>
                <span>{slide.kicker}</span>
              </p>
              <h2 class="workflow-title">{slide.title}</h2>
              <p class="workflow-body">{slide.description}</p>
              <div class="workflow-links">
                <a href={slide.primaryHref}>{slide.primaryLabel}</a>
                <a href={slide.secondaryHref}>{slide.secondaryLabel}</a>
              </div>
            </div>

            <div class="workflow-code">
              <p class="code-label">{slide.codeLabel}</p>
              <pre><code>{slide.code}</code></pre>
            </div>
          </article>
        ))
      }
    </div>

    <div class="carousel-controls" aria-label="Carousel controls">
      <button class="carousel-nav" type="button" data-prev aria-label="Previous slide">
        Previous
      </button>
      <div class="carousel-dots" role="tablist" aria-label="Select slide">
        {
          carouselSlides.map((_, index) => (
            <button
              class="carousel-dot"
              type="button"
              data-dot
              data-index={index}
              role="tab"
              aria-label={`Go to slide ${index + 1}`}
              aria-selected={index === 0 ? "true" : "false"}
            />
          ))
        }
      </div>
      <button class="carousel-nav" type="button" data-next aria-label="Next slide">
        Next
      </button>
    </div>
  </section>

  <div class="feature-grid" role="list" aria-label="LearnKit advanced highlights">
    {
      bottomFeatures.map(({ title, description, Icon }) => (
        <article class="feature-card" role="listitem">
          <p class="feature-title">
            <span class="feature-icon" aria-hidden="true">
              <Icon size={18} stroke-width={2.25} />
            </span>
            <span>{title}</span>
          </p>
          <p class="feature-body">{description}</p>
        </article>
      ))
    }
  </div>
</div>

<style>
  .home-panels {
    display: grid;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .feature-card {
    padding: 1.3rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.25rem;
    background: var(--card);
    box-shadow: 0 6px 18px color-mix(in oklab, var(--foreground) 4%, transparent);
  }

  .feature-grid > .feature-card:nth-child(2n) {
    margin-top: 0;
    top: auto;
    transform: none;
  }

  :global([data-theme="dark"]) .feature-card {
    background: color-mix(in oklab, var(--card) 96%, var(--muted));
    box-shadow: none;
  }

  .workflow-card {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.95fr);
    gap: 1.25rem;
    padding: 1.35rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 1.4rem;
    background: color-mix(in oklab, var(--card) 86%, var(--muted));
  }

  .workflow-carousel {
    display: grid;
    gap: 0.85rem;
  }

  .carousel-track {
    position: relative;
  }

  .workflow-slide {
    margin: 0;
  }

  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
  }

  .carousel-nav {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    background: var(--card);
    color: var(--foreground);
    font-weight: 600;
    cursor: pointer;
  }

  .carousel-nav:hover {
    background: color-mix(in oklab, var(--card) 84%, var(--muted));
  }

  .carousel-dots {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .carousel-dot {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    border: 0;
    background: color-mix(in oklab, var(--foreground) 18%, transparent);
    cursor: pointer;
  }

  .carousel-dot[aria-selected="true"] {
    background: var(--accent);
  }

  .workflow-copy,
  .workflow-code {
    min-width: 0;
  }

  .workflow-kicker {
    margin: 0 0 0.9rem;
  }

  .workflow-title {
    margin: 5px 0 0;
    font-size: clamp(1.5rem, 2vw, 2rem);
    line-height: 1.15;
    color: var(--foreground);
  }

  .workflow-body {
    margin: 0.9rem 0 0;
    color: var(--muted-foreground);
    line-height: 1.7;
  }

  .workflow-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.15rem;
  }

  .workflow-links a {
    color: var(--foreground);
    font-weight: 650;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--foreground) 22%, transparent);
  }

  .workflow-links a:hover {
    border-bottom-color: var(--foreground);
  }

  .workflow-code {
    align-self: stretch;
    padding: 1rem;
    border-radius: 1.1rem;
    background: color-mix(in oklab, var(--muted) 85%, var(--background));
    border: 1px solid color-mix(in oklab, var(--border) 88%, transparent);
  }

  .code-label {
    margin: 0 0 0.8rem;
    font-size: 0.82rem;
    font-weight: 650;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  .workflow-code pre {
    margin: 0;
    overflow-x: auto;
    font-size: 0.93rem;
    line-height: 1.7;
    color: var(--foreground);
    border: none;
  }

  .workflow-code code {
    font-family: var(--sl-font-mono, monospace);
  }

  .feature-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 0 0 0.7rem;
    font-size: 1rem;
    font-weight: 650;
    line-height: 1.3;
    color: var(--foreground);
  }

  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--primary) 12%, var(--background));
    color: var(--primary);
    flex: 0 0 auto;
  }

  .feature-body {
    margin: 0;
    color: var(--muted-foreground);
    line-height: 1.6;
  }

  @media (max-width: 60rem) {
    .workflow-card {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 50rem) {
    .feature-grid {
      grid-template-columns: 1fr;
    }

    .carousel-controls {
      justify-content: center;
      flex-wrap: wrap;
    }

    .workflow-card,
    .feature-card {
      padding: 1.1rem;
    }
  }
</style>

<script>
  (() => {
    const root = document.querySelector("[data-carousel]");
    if (!root) return;

    const slides = Array.from(root.querySelectorAll("[data-slide]"));
    const dots = Array.from(root.querySelectorAll("[data-dot]"));
    const prev = root.querySelector("[data-prev]");
    const next = root.querySelector("[data-next]");
    if (!slides.length || !prev || !next) return;

    let index = 0;

    const render = () => {
      slides.forEach((slide, slideIndex) => {
        const active = slideIndex === index;
        slide.toggleAttribute("hidden", !active);
      });

      dots.forEach((dot, dotIndex) => {
        dot.setAttribute("aria-selected", dotIndex === index ? "true" : "false");
      });
    };

    prev.addEventListener("click", () => {
      index = (index - 1 + slides.length) % slides.length;
      render();
    });

    next.addEventListener("click", () => {
      index = (index + 1) % slides.length;
      render();
    });

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const dotIndex = Number(dot.getAttribute("data-index"));
        if (Number.isNaN(dotIndex)) return;
        index = dotIndex;
        render();
      });
    });

    render();
  })();
</script>